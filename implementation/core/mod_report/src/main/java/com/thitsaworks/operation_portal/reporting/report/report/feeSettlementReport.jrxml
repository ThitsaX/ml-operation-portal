	<subDataset name="FeeSettlement" uuid="121b67a9-7c28-4a43-82a7-e655e270b7d9">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="central_ledger"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="318"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="677"/>
		<parameter name="startdate" class="java.lang.String"/>
		<parameter name="enddate" class="java.lang.String"/>
		<parameter name="fromfspid" class="java.lang.String"/>
		<parameter name="tofspid" class="java.lang.String"/>
		<parameter name="timezoneoffset" class="java.lang.String"/>
		<parameter name="currency" class="java.lang.String"/>
		<queryString language="plsql">
			<![CDATA[SELECT
                pCPayer.participantId as payerFspid,
                pPayer.name as payerFspName,
                pCPayee.participantId as payeeFspid,
                pPayee.name as payeeFspName,
                tF.transferId,
                tS.name as transactionType,
                tSS.name as transactionNature,
                DATE_FORMAT(CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ(tF.completedDate,'+00:00',CONCAT('-',SUBSTRING($P{timezoneoffset},2,2),':',SUBSTRING($P{timezoneoffset},4,2)))
                ELSE
                CONVERT_TZ(tF.completedDate,'+00:00',CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2))) END,"%d-%b-%Y" )as lastModifiedDate,
                pITPayer.name as payerIdentifierType,
                qpPayer.partyIdentifierValue as payerIdentifierValue,
                pITPayee.name as payeeIdentifierType,
                qpPayee.partyIdentifierValue as payeeIdentifierValue,
                ROUND(t.amount,2) as amount,
                c.currencyId,
				t.currencyId as currency,
                s.settlementId,
                s.createdDate as settlementCreatedDate,
                sSW.settlementWindowId,
                 DATE_FORMAT(CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ(NOW(),'+00:00',CONCAT('-',SUBSTRING($P{timezoneoffset},2,2),':',SUBSTRING($P{timezoneoffset},4,2)))
                ELSE
                CONVERT_TZ(NOW(),'+00:00',CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2))) END ,'%d-%b-%Y %h:%i:%s %p' ) AS getTodayDate,
                CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN $P{timezoneoffset} ELSE CONCAT('+',$P{timezoneoffset}) END AS timezoneoffset
            FROM
                transferFulfilment tF
                INNER JOIN transfer t ON t.transferId = tF.transferId
                INNER JOIN transferParticipant tPPayer ON tPPayer.transferId = tF.transferId
                    AND tPPayer.transferParticipantRoleTypeId = (SELECT transferParticipantRoleTypeId from transferParticipantRoleType WHERE name = 'PAYER_DFSP')
                    INNER JOIN participantCurrency pCPayer ON pCPayer.participantCurrencyId = tPPayer.participantCurrencyId
                    INNER JOIN participant pPayer ON pPayer.participantId = pCPayer.participantId
                INNER JOIN transferParticipant tPPayee ON tPPayee.transferId = tF.transferId
                    AND tPPayee.transferParticipantRoleTypeId = (SELECT transferParticipantRoleTypeId from transferParticipantRoleType WHERE name = 'PAYEE_DFSP')
                    INNER JOIN participantCurrency pCPayee ON pCPayee.participantCurrencyId = tPPayee.participantCurrencyId
                    INNER JOIN participant pPayee ON pPayee.participantId = pCPayee.participantId
                LEFT JOIN settlementWindow sW on sW.settlementWindowId = tF.settlementWindowId
                LEFT JOIN settlementSettlementWindow sSW on tF.settlementWindowId = sSW.settlementWindowId
                LEFT JOIN settlementWindowStateChange sWSC on sW.currentStateChangeId = sWSC.settlementWindowStateChangeId
                LEFT JOIN settlement s on sSW.settlementId = s.settlementId
                LEFT JOIN settlementModel sM ON sM.settlementModelId = s.settlementModelId
                LEFT JOIN currency c ON c.currencyId = sM.currencyId
                INNER JOIN quote q on q.transactionReferenceId = tF.transferId
                INNER JOIN quoteParty qpPayer on qpPayer.quoteId = q.quoteId AND qpPayer.partyTypeId = (SELECT partyTypeId FROM partyType WHERE name = 'PAYER')
                    INNER JOIN partyIdentifierType pITPayer ON pITPayer.partyIdentifierTypeId = qpPayer.partyIdentifierTypeId
                INNER JOIN quoteParty qpPayee on qpPayee.quoteId = q.quoteId AND qpPayee.partyTypeId = (SELECT partyTypeId FROM partyType WHERE name = 'PAYEE')
                    INNER JOIN partyIdentifierType pITPayee ON pITPayee.partyIdentifierTypeId = qpPayee.partyIdentifierTypeId
                INNER JOIN transactionScenario tS on tS.transactionScenarioId = q.transactionScenarioId
                LEFT JOIN transactionSubScenario tSS on tSS.transactionSubScenarioId = q.transactionSubScenarioId
            WHERE
                tF.isValid
                AND (tF.completedDate BETWEEN 
               (CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ($P{startdate},CONCAT(SUBSTRING($P{timezoneoffset},1,3),':',SUBSTRING($P{timezoneoffset},4,2)),'+00:00') ELSE
                CONVERT_TZ($P{startdate},CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2)) ,'+00:00') END) 
                AND 
                (CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ($P{enddate} ,CONCAT(SUBSTRING($P{timezoneoffset},1,3),':',SUBSTRING($P{timezoneoffset},4,2)),'+00:00') ELSE
                CONVERT_TZ($P{enddate},CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2)) ,'+00:00') END)) 
                AND pPayer.name = (CASE WHEN $P{fromfspid} = 'All' THEN pPayer.name ELSE $P{fromfspid} END)
                AND pPayee.name = (CASE WHEN $P{tofspid} = 'All' THEN pPayee.name ELSE $P{tofspid} END)
                AND TIMESTAMPDIFF(MONTH,$P{startdate},$P{enddate}) < 3
				AND t.currencyID=(CASE WHEN $P{currency} = 'All' THEN t.currencyID ELSE $P{currency} END)]]>
		</queryString>
		<field name="payerFspid" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="participantId"/>
			<property name="com.jaspersoft.studio.field.label" value="payerFspid"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="participantcurrency"/>
		</field>
