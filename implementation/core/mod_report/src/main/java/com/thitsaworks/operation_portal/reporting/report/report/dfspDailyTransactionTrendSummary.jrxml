	<subDataset name="DailyTrend" uuid="67507bdb-2a7e-4c2d-bc38-ac6346d316cf">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="central_ledger"/>
		<parameter name="timezoneoffset" class="java.lang.String">
			<parameterDescription><![CDATA[timezoneoffset]]></parameterDescription>
		</parameter>
		<parameter name="startdate" class="java.lang.String">
			<parameterDescription><![CDATA[startdate]]></parameterDescription>
		</parameter>
		<parameter name="enddate" class="java.lang.String">
			<parameterDescription><![CDATA[enddate]]></parameterDescription>
		</parameter>
		<queryString language="plsql">
			<![CDATA[SELECT 
                DATE(CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ(t.createdDate,'+00:00',CONCAT('-',SUBSTRING($P{timezoneoffset},2,2),':',SUBSTRING($P{timezoneoffset},4,2)))
                ELSE
                CONVERT_TZ(t.createdDate,'+00:00',CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2))) END )As CreatedDateOnly,
                COUNT(t.transferId) AS TotalTransaction,
                FORMAT(SUM(t.amount),2,'en_US')AS TotalAmount,
                CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ(NOW(),'+00:00',CONCAT('-',SUBSTRING($P{timezoneoffset},2,2),':',SUBSTRING($P{timezoneoffset},4,2)))
                ELSE
                CONVERT_TZ(NOW(),'+00:00',CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2))) END AS getTodayDate,
                CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN $P{timezoneoffset} ELSE CONCAT('+',$P{timezoneoffset}) END AS timezoneoffset
                
            FROM 
             	transfer t 
               INNER JOIN transferStateChange tsc ON t.transferId = tsc.transferId 
        		   	AND tsc.transferStateId ='COMMITTED'           
            WHERE 
                t.ilpCondition <>'0'
                AND  
                t.createdDate BETWEEN 
                (CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ($P{startdate},'+00:00',CONCAT('+',SUBSTRING($P{timezoneoffset},2,2),':',SUBSTRING($P{timezoneoffset},4,2))) ELSE
                CONVERT_TZ($P{startdate},'+00:00',CONCAT('-',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2))) END) 
                AND 
                (CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ( $P{enddate},'+00:00',CONCAT('+',SUBSTRING($P{timezoneoffset},2,2),':',SUBSTRING($P{timezoneoffset},4,2))) ELSE
                CONVERT_TZ( $P{enddate},'+00:00',CONCAT('-',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2))) END)GROUP BY CreatedDateOnly
                ORDER BY CreatedDateOnly]]>
		</queryString>
		<field name="CreatedDateOnly" class="java.sql.Date">
			<property name="com.jaspersoft.studio.field.name" value="CreatedDateOnly"/>
			<property name="com.jaspersoft.studio.field.label" value="CreatedDateOnly"/>
		</field>
		<field name="TotalTransaction" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="TotalTransaction"/>
			<property name="com.jaspersoft.studio.field.label" value="TotalTransaction"/>
		</field>
		<field name="TotalAmount" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="TotalAmount"/>
			<property name="com.jaspersoft.studio.field.label" value="TotalAmount"/>
		</field>
		<field name="getTodayDate" class="java.time.LocalDateTime">
			<property name="com.jaspersoft.studio.field.name" value="getTodayDate"/>
			<property name="com.jaspersoft.studio.field.label" value="getTodayDate"/>
		</field>
		<field name="timezoneoffset" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="timezoneoffset"/>
			<property name="com.jaspersoft.studio.field.label" value="timezoneoffset"/>
		</field>
	</subDataset>
