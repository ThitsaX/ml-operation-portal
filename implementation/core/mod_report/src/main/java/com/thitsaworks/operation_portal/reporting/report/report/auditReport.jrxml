    <subDataset name="auditDB" uuid="d44912b1-e131-4631-999f-7ae1ee4d6871">
        <property name="com.jaspersoft.studio.data.sql.tables" value=""/>
        <property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter"/>
        <parameter name="realmId" class="java.lang.String">
            <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
        </parameter>
        <parameter name="fromDate" class="java.lang.Long"/>
        <parameter name="toDate" class="java.lang.Long"/>
        <parameter name="timezoneoffset" class="java.lang.String">
            <defaultValueExpression><![CDATA["+06:30"]]></defaultValueExpression>
        </parameter>
        <parameter name="userId" class="java.lang.String">
            <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
        </parameter>
        <parameter name="actionId" class="java.lang.String">
            <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
        </parameter>
        <parameter name="grantedActionList" class="java.util.List">
            <defaultValueExpression><![CDATA[null]]></defaultValueExpression>
        </parameter>
        <parameter name="offset" class="java.lang.Integer">
            <defaultValueExpression><![CDATA[0]]></defaultValueExpression>
        </parameter>
        <parameter name="limit" class="java.lang.Integer">
            <defaultValueExpression><![CDATA[2147483647]]></defaultValueExpression>
        </parameter>
        <queryString language="plsql">
            <![CDATA[SELECT
    CASE
        WHEN tac.action_code LIKE '%Scheduler' AND tu.email IS NULL
        THEN CONCAT(SUBSTRING(tac.action_code, 1, LENGTH(tac.action_code) - LENGTH('Scheduler')), 'Automatically')
        ELSE tu.email
    END AS user,
    tac.action_code AS action_name,
    CONCAT(
    DATE_FORMAT(
        CASE
            WHEN TIMEDIFF(NOW(), UTC_TIMESTAMP()) = CONCAT(SUBSTRING($P{timezoneoffset}, 2), ':00') THEN
                FROM_UNIXTIME(ta.created_date)
            ELSE
                CONVERT_TZ(FROM_UNIXTIME(ta.created_date), '+00:00', $P{timezoneoffset})
        END,
        '%Y-%m-%dT%H:%i:%s'
    ), $P{timezoneoffset}
) AS date
FROM tbl_audit AS ta
LEFT JOIN tbl_participant AS tp ON tp.participant_id = ta.participant_id
LEFT JOIN tbl_user AS tu ON tu.user_id = ta.user_id
JOIN tbl_action AS tac ON tac.action_id = ta.action_id
WHERE
  ($P{realmId} IS NULL OR $P{realmId} = '' OR ta.participant_id = $P{realmId})
  AND (
    ($P{fromDate} IS NULL OR $P{toDate} IS NULL)
    OR (
            ta.created_date BETWEEN $P{fromDate} AND $P{toDate}
    )
  )
    AND ($P{userId} IS NULL OR  $P{userId} = '' OR ta.user_id = $P{userId})
    AND ($P{actionId} IS NULL OR   $P{actionId} = '' OR tac.action_id = $P{actionId})
    AND ($X{IN, tac.action_id, grantedActionList})
ORDER BY ta.created_date DESC
LIMIT $P{limit} OFFSET $P{offset}]]>
        </queryString>
        <field name="date" class="java.lang.String"/>
        <field name="user" class="java.lang.String"/>
        <field name="action_name" class="java.lang.String"/>
    </subDataset>
