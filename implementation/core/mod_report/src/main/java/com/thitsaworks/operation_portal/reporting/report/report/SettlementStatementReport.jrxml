	<subDataset name="StatementDb" uuid="121b67a9-7c28-4a43-82a7-e655e270b7d9">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CentralLedgerAdapter"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w1" value="318"/>
		<property name="com.jaspersoft.studio.data.sql.SQLQueryDesigner.sash.w2" value="677"/>
		<parameter name="dfspId" class="java.lang.String"/>
		<parameter name="startDate" class="java.lang.String"/>
		<parameter name="endDate" class="java.lang.String"/>
		<parameter name="currencyId" class="java.lang.String"/>
		<parameter name="timezoneoffset" class="java.lang.String"/>
		<queryString language="plsql">
			<![CDATA[SELECT CONCAT(DATE_FORMAT(CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
       CONVERT_TZ(tp.createdDate, '+00:00', CONCAT('-', SUBSTRING($P{timezoneoffset},2,2), ':', SUBSTRING($P{timezoneoffset},4,2)))
       ELSE CONVERT_TZ(tp.createdDate, '+00:00', CONCAT('+', SUBSTRING($P{timezoneoffset},1,2), ':', SUBSTRING($P{timezoneoffset},3,2)))
      END,'%Y-%m-%dT%H:%i:%s'),
      CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN CONCAT('-', SUBSTRING($P{timezoneoffset},2,2), ':', SUBSTRING($P{timezoneoffset},4,2))
      ELSE CONCAT('+', SUBSTRING($P{timezoneoffset},1,2), ':', SUBSTRING($P{timezoneoffset},3,2)) END) AS createdDate,
		 p.name AS dfspId, p.name AS dfspName, COALESCE(tscIn.reason, tscOut.reason) AS processDescription, 
ROUND(CASE WHEN tp.amount < 0 THEN -tp.amount END, 2) AS fundsIn,
ROUND(CASE WHEN tp.amount > 0 THEN  tp.amount END, 2) AS fundsOut,
		  ROUND(ppc.value, 2) AS balance, 
		 COALESCE(texNdcPercent.value, '-') AS ndcPercent,
		 COALESCE(texNdc.value, '0') AS ndc,
		 pc.currencyId AS currency,
		 COALESCE(texBankAccount.value, '') AS settlementBankAccount
FROM participant p
INNER JOIN participantCurrency pc ON p.participantId = pc.participantId
INNER JOIN ledgerAccountType lat ON lat.ledgerAccountTypeId = pc.ledgerAccountTypeId
INNER JOIN transferParticipant tp ON tp.participantCurrencyId = pc.participantCurrencyId
LEFT JOIN transferStateChange tscOut ON tp.transferId = tscOut.transferId AND tscOut.transferStateChangeId = (SELECT MAX(transferStateChangeId) FROM transferStateChange tscOut1 WHERE tscOut1.transferId = tp.transferId
			 AND tscOut1.transferStateId in ('RESERVED', 'ABORTED_REJECTED'))
LEFT JOIN transferState tsOut ON tscOut.transferStateId = tsOut.transferStateId
LEFT JOIN transferStateChange tscIn ON tp.transferId = tscIn.transferId AND tscIn.transferStateChangeId = (SELECT MAX(transferStateChangeId) FROM transferStateChange tscIn1 WHERE tscIn1.transferId = tp.transferId
			 AND tscIn1.transferStateId in ('COMMITTED', 'ABORTED_REJECTED'))
LEFT JOIN transferState tsIn ON tscIn.transferStateId = tsIn.transferStateId
INNER JOIN participantPosition pp ON pp.participantCurrencyId = pc.participantCurrencyId
INNER JOIN participantPositionChange ppc ON ppc.participantPositionId = pp.participantPositionId
INNER JOIN currency c ON c.currencyId = pc.currencyId
LEFT JOIN transferExtension tex ON tex.transferId = tp.transferId 
LEFT JOIN transferExtension texNdc ON texNdc.transferId = tp.transferId AND texNdc.key = 'opNdc'
LEFT JOIN transferExtension texNdcPercent ON texNdcPercent.transferId = tp.transferId AND texNdcPercent.key = 'opNdcPercent'
LEFT JOIN transferExtension texBankAccount ON texBankAccount.transferId = tp.transferId AND texBankAccount.key = 'opBankAccount'
 
WHERE ($P{dfspId} ='All' OR p.name = $P{dfspId})
AND (tscIn.transferStateChangeId = ppc.transferStateChangeId OR tscOut.transferStateChangeId = ppc.transferStateChangeId)
AND tex.transferExtensionId = (SELECT MAX(transferExtensionId) FROM transferExtension tex WHERE tex.transferId = tp.transferId AND tex.key = 'externalReference')
AND (tp.createdDate BETWEEN (CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ($P{startDate},CONCAT(SUBSTRING($P{timezoneoffset},1,3),':',SUBSTRING($P{timezoneoffset},4,2)),'+00:00') ELSE
                CONVERT_TZ($P{startDate},CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2)) ,'+00:00') END) 
                AND 
                (CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
                CONVERT_TZ($P{endDate} ,CONCAT(SUBSTRING($P{timezoneoffset},1,3),':',SUBSTRING($P{timezoneoffset},4,2)),'+00:00') ELSE
                CONVERT_TZ($P{endDate},CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2)) ,'+00:00') END))
			 AND ($P{currencyId} = 'All' OR pc.currencyId= $P{currencyId})
 
GROUP BY tp.createdDate, p.participantId, p.name, tscIn.reason, tscOut.reason, 
         tp.amount, ppc.value, pc.currencyId,pc.participantCurrencyId,texNdcPercent.value, texNdc.value, texBankAccount.value
ORDER BY p.name, pc.currencyId, pc.participantCurrencyId,  tp.createdDate;]]>
		</queryString>
		<field name="createdDate" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="createdDate"/>
			<property name="com.jaspersoft.studio.field.label" value="createdDate"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="createdDate"/>
		</field>
