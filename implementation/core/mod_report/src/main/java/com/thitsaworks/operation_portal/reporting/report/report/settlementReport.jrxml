		</field>
		<field name="currencyScale" class="java.lang.Long">
			<property name="com.jaspersoft.studio.field.name" value="currencyScale"/>
			<property name="com.jaspersoft.studio.field.label" value="currencyScale"/>
		</field>
		<field name="sentAmount" class="java.math.BigDecimal">
