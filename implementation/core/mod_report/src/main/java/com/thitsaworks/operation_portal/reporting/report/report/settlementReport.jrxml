		<field name="receivedVolume" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="receivedVolume"/>
			<property name="com.jaspersoft.studio.field.label" value="receivedVolume"/>
		</field>
		<field name="totalAmount" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="totalAmount"/>
			<property name="com.jaspersoft.studio.field.label" value="totalAmount"/>
		</field>
		<field name="totalVolume" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="totalVolume"/>
			<property name="com.jaspersoft.studio.field.label" value="totalVolume"/>
		</field>
		<field name="netAmount" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.name" value="netAmount"/>
			<property name="com.jaspersoft.studio.field.label" value="netAmount"/>
		</field>
		<field name="createdDate" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="createdDate"/>
			<property name="com.jaspersoft.studio.field.label" value="createdDate"/>
		</field>
		<field name="timezoneoffset" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="timezoneoffset"/>
			<property name="com.jaspersoft.studio.field.label" value="timezoneoffset"/>
		</field>
		<field name="lastActionDate" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="lastActionDate"/>
			<property name="com.jaspersoft.studio.field.label" value="lastActionDate"/>
		</field>
		<variable name="netAmount1" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{netAmount}]]></variableExpression>
		</variable>
		<variable name="netAmount2" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{netAmount}]]></variableExpression>
		</variable>
		<variable name="settlementCreatedDate" class="java.lang.String" calculation="First">
			<variableExpression><![CDATA[$F{createdDate}]]></variableExpression>
		</variable>
