	<subDataset name="Settlement" uuid="15078201-d94c-4c10-880d-5eed846ea4ee">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="JDBC Adapter"/>
		<parameter name="dfspId" class="java.lang.String"/>
		<parameter name="dfspName" class="java.lang.String"/>
		<parameter name="settlementId" class="java.lang.String"/>
		<parameter name="timezoneoffset" class="java.lang.String"/>
		<queryString language="plsql">
			<![CDATA[SELECT settlementId,
       settlementWindowId,
       p.participantId,
       p.name,
       currencyId,
       currencyScale,
       ROUND(sentAmount,2) as sentAmount,
       sentVolume,
       ROUND( receivedAmount,2) as receivedAmount,
       receivedVolume,
       ROUND( (sentAmount + receivedAmount) ,2)as totalAmount,
       (sentVolume + receivedVolume) as totalVolume,
       ROUND((receivedAmount - sentAmount),2) as netAmount,
       CONCAT(
					DATE_FORMAT(CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
					CONVERT_TZ(s3.createdDate, '+00:00', CONCAT('-', SUBSTRING($P{timezoneoffset},2,2), ':', SUBSTRING($P{timezoneoffset},4,2)))
					ELSE CONVERT_TZ(s3.createdDate, '+00:00', CONCAT('+', SUBSTRING($P{timezoneoffset},1,2), ':', SUBSTRING($P{timezoneoffset},3,2)))
					END,'%Y-%m-%dT%H:%i:%s'),
					CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN CONCAT('-', SUBSTRING($P{timezoneoffset},2,2), ':', SUBSTRING($P{timezoneoffset},4,2))
					ELSE CONCAT('+', SUBSTRING($P{timezoneoffset},1,2), ':', SUBSTRING($P{timezoneoffset},3,2)) END
		 ) AS createdDate, 
		CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN CONCAT('-', SUBSTRING($P{timezoneoffset},1,2), ':', SUBSTRING($P{timezoneoffset},3,2)) ELSE CONCAT('+', SUBSTRING($P{timezoneoffset},1,2), ':', SUBSTRING($P{timezoneoffset},3,2)) END AS timezoneoffset,
		DATE_FORMAT( CASE WHEN SUBSTRING($P{timezoneoffset},1,1) = '-' THEN 
		CONVERT_TZ(lastActionDate,'+00:00',CONCAT('-',SUBSTRING($P{timezoneoffset},2,2),':',SUBSTRING($P{timezoneoffset},4,2)))
		ELSE CONVERT_TZ(lastActionDate,'+00:00',CONCAT('+',SUBSTRING($P{timezoneoffset},1,2),':',SUBSTRING($P{timezoneoffset},3,2))) END ,'%d-%b-%Y %h:%i:%s %p')as lastActionDate
FROM participant p INNER JOIN
    (
        SELECT settlementId,
               settlementWindowId,
               MAX(currencyId) as currencyId,
               MAX(currencyScale) as currencyScale,
               participantId,
               SUM(sentAmount)     as sentAmount,
               SUM(sentVolume)     as sentVolume,
               SUM(receivedAmount) as receivedAmount,
               SUM(receivedVolume) as receivedVolume,
               MAX(createdDate) as createdDate,
               MAX(lastActionDate) as lastActionDate
        FROM (
                 SELECT settlementId,
                        settlementWindowId,
                        MAX(createdDate) as createdDate,
                        MAX(lastActionDate) as lastActionDate,
                        MAX(currencyId) as currencyId,
                        MAX(currencyScale) as currencyScale,
                        IF(senderName != $P{dfspId}, senderId, receiverId) as participantId,
                        SUM(IF(senderName = $P{dfspId}, amount, 0))       as sentAmount,
                        SUM(IF(senderName = $P{dfspId}, volume, 0))       as sentVolume,
                        SUM(IF(receiverName = $P{dfspId}, amount, 0))     as receivedAmount,
                        SUM(IF(receiverName = $P{dfspId}, volume, 0))     as receivedVolume
                 FROM (
                          SELECT MAX(CASE WHEN tP.amount > 0 THEN p.participantId END) as senderId,
                                 MAX(CASE WHEN tP.amount < 0 THEN p.participantId END) as receiverId,
                                 MAX(CASE WHEN tP.amount > 0 THEN p.name END)          as senderName,
                                 MAX(CASE WHEN tP.amount < 0 THEN p.name END)          as receiverName,
                                 MAX(tP.amount)                                        as amount,
                                 MAX(c.currencyId)                                     as currencyId,
                                 MAX(c.scale)                                          as currencyScale,
                                 COUNT(DISTINCT (tF.transferId))                       as volume,
                                 s.settlementId,
                                 sSW.settlementWindowId,
                                 MAX(s.createdDate) as createdDate,
                                 MAX(tF.completedDate) as lastActionDate
                          FROM transferParticipant tP
                                   INNER JOIN transferFulfilment tF on tP.transferId = tF.transferId
                                   INNER JOIN settlementSettlementWindow sSW
                                              on tF.settlementWindowId = sSW.settlementWindowId
                                   INNER JOIN settlementWindowStateChange sWSC
                                              on sSW.settlementWindowId = sWSC.settlementWindowId
                                   INNER JOIN settlement s on sSW.settlementId = s.settlementId                                          
                                   INNER JOIN participantCurrency pC
                                              on tP.participantCurrencyId = pC.participantCurrencyId                                                      
                                   INNER JOIN currency c on c.currencyId = pC.currencyId
                                   INNER JOIN participant p on pC.participantId = p.participantId
                          WHERE tF.isValid
                            AND sWSC.settlementWindowStateId = 'CLOSED'
                            AND s.settlementId = $P{settlementId}
                          GROUP BY tF.transferId, s.settlementId,pC.currencyId
                      ) s
                 WHERE s.senderName = $P{dfspId}
                    OR s.receiverName = $P{dfspId}
                 GROUP BY settlementId, settlementWindowId, senderId, receiverId, senderName, receiverName,s.currencyId
             ) s2

        GROUP BY settlementId, settlementWindowId, participantId,s2.currencyId
    ) s3 ON p.participantId = s3.participantId
WHERE p.name != 'Hub'
ORDER BY p.name, settlementWindowId]]>
		</queryString>
