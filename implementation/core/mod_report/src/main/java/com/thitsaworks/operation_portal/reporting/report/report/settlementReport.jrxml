		<band height="97">
			<textField>
				<reportElement x="1250" y="70" width="300" height="20" uuid="1fbb8334-41ad-4beb-8117-ad1c6de4ac9c">
					<property name="net.sf.jasperreports.export.pdf" value="true"/>
				</reportElement>
				<textElement textAlignment="Right">
					<font fontName="Calibri" size="11" isItalic="false"/>
				</textElement>
				<textFieldExpression><![CDATA["PDF".equalsIgnoreCase($P{report})
? (
    "Printed by: " + $P{user} + " on " +
 
    new java.text.SimpleDateFormat("M/dd/yyyy hh:mm a").format(
        new java.util.Date(
            System.currentTimeMillis()
            + (
                // detect sign
                ($P{timezoneoffset}.startsWith("-") ? -1 : 1)
                *
                (
                    // hours
                    Integer.parseInt(
                        $P{timezoneoffset}
                            .replace(":", "")
                            .replace("-", "")
                            .substring(0, 2)
                    ) * 60 * 60 * 1000L
                  +
                    // minutes
                    Integer.parseInt(
                        $P{timezoneoffset}
                            .replace(":", "")
                            .replace("-", "")
                            .substring(2, 4)
                    ) * 60 * 1000L
                )
            )
        )
    )
)
: ""]]></textFieldExpression>
			</textField>
		</band>
	</pageFooter>
