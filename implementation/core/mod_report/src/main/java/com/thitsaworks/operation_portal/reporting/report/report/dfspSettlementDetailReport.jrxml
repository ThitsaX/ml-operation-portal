			<property name="com.jaspersoft.studio.field.tree.path" value="transferfulfilment"/>
		</field>
		<field name="transactionType" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="name"/>
			<property name="com.jaspersoft.studio.field.label" value="transactionType"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="transactionscenario"/>
		</field>
		<field name="transactionNature" class="java.lang.String">
