			<property name="com.jaspersoft.studio.field.label" value="transactionNature"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="transactionsubscenario"/>
		</field>
		<field name="lastModifiedDate" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="lastModifiedDate"/>
			<property name="com.jaspersoft.studio.field.label" value="lastModifiedDate"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="transferfulfilment"/>
		</field>
		<field name="payerIdentifierType" class="java.lang.String">
