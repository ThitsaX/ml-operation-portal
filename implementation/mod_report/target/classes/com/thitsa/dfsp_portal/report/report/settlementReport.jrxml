			<property name="com.jaspersoft.studio.field.name" value="netAmount"/>
			<property name="com.jaspersoft.studio.field.label" value="netAmount"/>
		</field>
		<field name="createdDate" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="createdDate"/>
			<property name="com.jaspersoft.studio.field.label" value="createdDate"/>
		</field>
		<field name="lastActionDate" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="lastActionDate"/>
			<property name="com.jaspersoft.studio.field.label" value="lastActionDate"/>
		</field>
		<variable name="netAmount1" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{netAmount}]]></variableExpression>
		</variable>
		<variable name="netAmount2" class="java.math.BigDecimal" calculation="Sum">
			<variableExpression><![CDATA[$F{netAmount}]]></variableExpression>
		</variable>
		<variable name="Variable_1" class="java.lang.String" calculation="Sum">
			<variableExpression><![CDATA[$F{netAmount}]]></variableExpression>
		</variable>
